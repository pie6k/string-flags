{
  "name": "string-flags",
  "version": "0.1.4",
  "description": "Developer-friendly, production-ready, human-readable alternative to binary flags.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && vite build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepack": "yarn typecheck && yarn test && yarn build",
    "release": "yarn version patch && yarn npm publish",
    "release:patch": "yarn version patch && yarn npm publish",
    "release:minor": "yarn version minor && yarn npm publish",
    "release:major": "yarn version major && yarn npm publish"
  },
  "keywords": [
    "flags",
    "bitmask",
    "bitfield",
    "string-flags",
    "enum",
    "typescript",
    "state"
  ],
  "author": "Adam Pietrasiak <adam@pietrasiak.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pietrasiak/string-flags.git"
  },
  "bugs": {
    "url": "https://github.com/pietrasiak/string-flags/issues"
  },
  "homepage": "https://github.com/pietrasiak/string-flags#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
